  "transactions": "TRX-WORKFLOW-001",
  "amount": 45.00,
  "initiator": "user",
  "created_at": "2025-01-15T15:00:00Z",
  "completed": "2025-01-15T15:01:00Z",
  "hash": "00000000-0000-0000-0000-000000000200",
  "session_id": "00000000-0000-0000-0000-000000000300",
  "parking_lot_id": "00000000-0000-0000-0000-000000000400"
}

@workflowPaymentId = 00000000-0000-0000-0000-000000000100

###

### Step 2: Verify payment exists (as user)
GET {{baseUrl}}/api/payments/{{workflowPaymentId}}
Authorization: Bearer {{userToken}}

###

### Step 3: Admin updates the payment
PUT {{baseUrl}}/api/payments/update/{{workflowPaymentId}}
Content-Type: {{contentType}}
Authorization: Bearer {{lotAdminToken}}

{
  "id": "{{workflowPaymentId}}",
  "reservation_id": "00000000-0000-0000-0000-000000000200",
  "paid_at": "2025-01-15T15:00:00Z",
  "transactions": "TRX-WORKFLOW-001-UPDATED",
  "amount": 50.00,
  "initiator": "lotadmin",
  "created_at": "2025-01-15T15:00:00Z",
  "completed": "2025-01-15T15:05:00Z",
  "hash": "00000000-0000-0000-0000-000000000200",
  "session_id": "00000000-0000-0000-0000-000000000300",
  "parking_lot_id": "00000000-0000-0000-0000-000000000400"
}

###

### Step 4: SuperAdmin deletes the payment
