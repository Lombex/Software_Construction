### ============================================
### Payment API - Comprehensive Test Suite
### ============================================
### Base URL
@baseUrl = http://localhost:5001
@contentType = application/json

### ============================================
### STEP 1: LOGIN TO GET TOKENS
### ============================================

### Login as SuperAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "Username": "superadmin",
  "Password": "superpass"
}

### Copy the token from response and paste it below
@superAdminToken = YOUR_SUPERADMIN_TOKEN_HERE

###

### Login as ParkingLotAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "Username": "lotadmin",
  "Password": "lotpass"
}

### Copy the token from response and paste it below
@lotAdminToken = YOUR_LOTADMIN_TOKEN_HERE

###

### Login as Regular User
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "Username": "user",
  "Password": "userpass"
}

### Copy the token from response and paste it below
@userToken = YOUR_USER_TOKEN_HERE

###

