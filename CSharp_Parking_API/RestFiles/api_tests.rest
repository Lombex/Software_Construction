  "Username": "superadmin",
  "Password": "superpass"
}

### Save SuperAdmin token (copy from response) REPLACE ON TEST, USE LOGIN TO GET TOKEN
@superAdminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..A0U31osbb3zwsA4JbMrs6Em0y4zqeRGkQxaZniCIUDQ

###

### 2. Login as ParkingLotAdmin
