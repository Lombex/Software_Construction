###
# Get all billing records (admin only)
GET http://localhost:5000/api/billing/all
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

###
# Get current user's billing records
GET http://localhost:5000/api/billing/mine
Authorization: Bearer YOUR_USER_TOKEN_HERE

###
# Create a new billing record (admin only)
POST http://localhost:5000/api/billing/create
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE
Content-Type: application/json

{
  "user_id": "PASTE_VALID_USER_ID_HERE",
  "session_id": null,
  "reservation_id": null,
  "payment_id": null,
  "amount": 25.50,
  "currency": "EUR",
  "description": "Test bill",
  "due_date": "2026-01-15T00:00:00Z",
  "paid": false,
  "created_at": "2026-01-09T00:00:00Z",
  "paid_at": null,
  "invoice_number": null,
  "type": 0,
  "status": 0
}

###
# Delete a billing record (SuperAdmin only)
DELETE http://localhost:5000/api/billing/delete/PASTE_BILL_ID_HERE
Authorization: Bearer YOUR_SUPERADMIN_TOKEN_HERE

###
# Get a billing record by ID
GET http://localhost:5000/api/billing/PASTE_BILL_ID_HERE
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

###
# Mark a bill as paid
POST http://localhost:5000/api/billing/PASTE_BILL_ID_HERE/mark-paid
Authorization: Bearer YOUR_USER_OR_ADMIN_TOKEN_HERE

###
# Cancel a bill (admin only)
POST http://localhost:5000/api/billing/PASTE_BILL_ID_HERE/cancel
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

###
# Update a billing record
PUT http://localhost:5000/api/billing/update/PASTE_BILL_ID_HERE
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE
Content-Type: application/json

{
  "amount": 30.00,
  "currency": "EUR",
  "description": "Updated bill",
  "due_date": "2026-01-20T00:00:00Z",
  "status": 1
}

###
# Get monthly bundle invoices for a user (admin only)
GET http://localhost:5000/api/billing/monthly-bundle/PASTE_USER_ID_HERE?month=2026-01-01
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE