    [Fact]
    public async Task Test_UpdateParkinglot_NotFound()
    {
        var client = _factory.CreateClient();
        client.DefaultRequestHeaders.Authorization = await Utils.AuthenticateAsync(client);

        var lot = CreateSampleParkinglot();
